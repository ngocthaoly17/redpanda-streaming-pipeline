FROM apache/spark:3.5.1-scala2.12-java17-python3-ubuntu

USER root
WORKDIR /app

ENV PATH="/opt/spark/bin:${PATH}"

COPY spark_redpanda_analysis.py wait_for_redpanda.sh run_spark.sh ./

RUN chmod +x /app/wait_for_redpanda.sh /app/run_spark.sh \
    && mkdir -p /app/output /app/checkpoints /home/spark/.ivy2/cache /home/spark/.ivy2/jars \
    && chown -R spark:spark /app /home/spark/.ivy2

USER spark

CMD ["/bin/bash", "/app/run_spark.sh"]